{
  "name": "@his-and-hers/core",
  "version": "0.2.0",
  "description": "Cross-machine pairing protocol, handoff message schema, trust model, peer discovery, WOL, SSH transport",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CalciferFriend/his-and-hers",
    "directory": "packages/core"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./protocol": {
      "import": "./dist/protocol/index.js",
      "types": "./dist/protocol/index.d.ts"
    },
    "./transport": {
      "import": "./dist/transport/index.js",
      "types": "./dist/transport/index.d.ts"
    },
    "./notify/config": {
      "import": "./dist/notify/config.js",
      "types": "./dist/notify/config.d.ts"
    },
    "./notify/notify": {
      "import": "./dist/notify/notify.js",
      "types": "./dist/notify/notify.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "agents",
    "protocol",
    "cross-machine",
    "wake-on-lan",
    "tailscale",
    "ssh",
    "pairing"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsdown": "^0.9.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
