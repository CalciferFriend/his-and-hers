# docker/.env.example — copy to docker/.env and fill in your values
# Never commit docker/.env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Tailscale ephemeral auth key — generate at https://login.tailscale.com/admin/authkeys
# Use an ephemeral+reusable key so the container can re-auth on restart
TS_AUTHKEY=tskey-auth-...

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Tom identity (optional) ───────────────────────────────────────────────────
TOM_NAME=Tom
TOM_EMOJI=🐱
TOM_MODEL=claude-sonnet-4-6
TOM_GATEWAY_PORT=18789

# Leave blank to auto-generate a secure token on first boot.
# After first boot, find it in docker logs or /root/.openclaw/openclaw.json.
TOM_GATEWAY_TOKEN=

# ── Jerry peer connection ─────────────────────────────────────────────────────
# Fill in after running `tj onboard` on the Jerry (Windows) machine.
JERRY_TAILSCALE_HOSTNAME=
JERRY_TAILSCALE_IP=
JERRY_GATEWAY_PORT=18789
JERRY_GATEWAY_TOKEN=
JERRY_SSH_USER=

# ── Wake-on-LAN (optional) ────────────────────────────────────────────────────
JERRY_WOL_ENABLED=false
JERRY_WOL_MAC=
JERRY_WOL_BROADCAST=
