# .env.example — his-and-hers Docker environment
# Copy to .env and fill in your values:
#   cp docker/.env.example docker/.env
#
# Then start:
#   docker compose -f docker/docker-compose.yml up -d        # H1 only
#   docker compose -f docker/docker-compose.yml --profile h2-cpu up -d
#   docker compose -f docker/docker-compose.yml --profile h2-cuda up -d

# ─── Tailscale ────────────────────────────────────────────────────────────────
# Get an auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable key if running multiple containers, or ephemeral for one-shot.
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXX

# If H1 and H2 have separate Tailscale accounts/tailnets, set both:
# JERRY_TS_AUTHKEY=tskey-auth-...

# ─── H1 (orchestrator) ───────────────────────────────────────────────────────
H1_NAME=H1
TOM_EMOJI=🐱
TOM_MODEL=claude-sonnet-4-6
TOM_GATEWAY_PORT=18789
TOM_GATEWAY_TOKEN=   # leave empty to auto-generate on first boot

# AI provider key — Anthropic by default
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXX

# ─── H2 (executor) — fill in after hh onboard on H2, or run h2-cpu/cuda profile ──
H2_NAME=H2
JERRY_EMOJI=🐭
JERRY_MODEL=llama3.2
JERRY_PROVIDER=ollama
JERRY_GATEWAY_PORT=18789
JERRY_GATEWAY_TOKEN=   # leave empty to auto-generate

# Models to pull at startup (comma-separated)
# Examples: llama3.2,mistral,codellama:13b,llava:13b
JERRY_OLLAMA_MODELS=llama3.2

# H2's Tailscale info (from H2's startup logs or `hh status` on H2)
JERRY_TAILSCALE_HOSTNAME=h2-h2-docker
JERRY_TAILSCALE_IP=100.x.y.z
JERRY_SSH_USER=root

# H1's SSH public key (paste the contents of ~/.ssh/id_ed25519.pub here)
# H2 will add this to its authorized_keys so H1 can SSH in for task delivery
TOM_SSH_PUBKEY=

# Reverse: H1's Tailscale IP (for H2 to know where to report back)
TOM_TAILSCALE_IP=100.a.b.c

# Wake-on-LAN (optional — for physical H2 machines)
JERRY_WOL_ENABLED=false
JERRY_WOL_MAC=
JERRY_WOL_BROADCAST=
