# # cofounder environment variables
# Copy to .env and fill in values

# LLM provider API key (stored in OS keychain by wizard, env var as fallback)
# TJ_API_KEY=

# Override config path (default: ~/.cofounder/cofounder.json)
# TJ_CONFIG_PATH=

# Log level: debug | info | warn | error
TJ_LOG_LEVEL=info
